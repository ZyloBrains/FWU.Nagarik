@page
@{
    Layout = "_LayoutCertificate";
    ViewData["Title"] = "Provisional Certificate";
}

<style>
    .certificate {
        padding: 22mm 28mm;
    }

    .university-name {
        font-size: 32px;
        margin-bottom: 10px;
    }

    .office-text {
        font-size: 14px;
        margin-top: 8px;
    }

    .logo-container {
        margin: 15px 0;
    }

    .main-logo {
        width: 100px;
        height: 100px;
    }

    .doc-title {
        font-size: 22px;
        margin: 20px 0 30px;
        padding-bottom: 10px;
    }

    .form-body {
        font-size: 14px;
        line-height: 2.2;
    }

    .form-body p {
        margin-bottom: 18px;
    }

    .footer-wrap {
        margin-top: 40px;
    }

    .sig-row {
        max-width: 520px;
        margin-bottom: 30px;
    }

    .sig-block {
        width: 30%;
    }

    .issue-date {
        max-width: 520px;
    }

    .date-val {
        min-width: 140px;
    }

    .seal-placeholder {
        width: 70px;
        height: 70px;
        font-size: 8px;
        line-height: 1.3;
    }
</style>


<div class="cert-no">
    Serial No: <span>2312</span>
</div>

<div class="content">
    <div class="university-header">
        <div class="university-name">Far Western University</div>
        <div class="office-text">Office of Controller of Examinations</div>
        <div class="university tagline">Mahendranagar, Kanchanpur, Nepal</div>
    </div>

    <div class="logo-container">
        <svg class="main-logo" viewBox="0 0 100 100">
            <image href="~/images/fwu.png" x="2" y="2" width="96" height="96" />
            <circle cx="50" cy="50" r="49" fill="none" stroke="#1a365d" stroke-width="1" />
        </svg>
    </div>

    <div class="doc-title">Provisional Certificate</div>

    <div class="form-body">
        <p>
            This is to certify that <span class="data-highlight" style="min-width: 350px;">AAISHA KUMARI KUNWAR</span>,
            son/daughter of <span class="data-highlight">[Father's Name]</span> having
            <span class="label">F.W.U. Registration No:</span> <span class="data-highlight">MG-2022-1-16-2142</span>
            has successfully completed the prescribed course of study for the degree of
            <span class="data-highlight">BACHELOR OF BUSINESS MANAGEMENT</span> at
            <span class="data-highlight">KAILALI MULTIPLE CAMPUS</span>.
        </p>

        <p>
            <span class="label">Date of Birth:</span> <span class="data-highlight">1946-08-17</span> B.S.
            (<span class="data-highlight">2003-05-01</span> A.D.)
        </p>

        <p>
            This certificate is issued provisionally for the purpose of
            <span class="data-highlight">[Purpose]</span>.
        </p>
    </div>

    <div class="footer">
        <div class="sig-row">
            <div class="sig-block">
                <div class="sig-line">Prepared by</div>
            </div>
            <div class="sig-block">
                <div class="sig-line">Checked by</div>
            </div>
            <div class="sig-block">
                <div class="sig-line">Controller of Examinations</div>
            </div>
        </div>

        <div class="footer-bottom">
            <span>DATE OF ISSUE: <span class="date-val">January 21, 2026</span></span>
            <div class="seal-placeholder">University<br>Seal</div>
        </div>
    </div>
</div>