@page
@model FWU.Nagarik.Api.Pages.Dashboard.StudentRequestsModel
@using FWU.Nagarik.Api.Enums
@{
    ViewData["Title"] = "Student Requests";
    var docTypes = Enum.GetValues<DocumentType>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-file-earmark-text"></i> Student Requests</h2>
    <div class="d-flex align-items-center gap-3">
        @if (Model.LastSyncTime.HasValue)
        {
            <small class="text-muted">Last sync: @Model.LastSyncTime.Value.ToLocalTime()</small>
        }
        <form method="post" asp-page-handler="Sync">
            <button type="submit" class="btn btn-primary" disabled="@Model.IsSyncing">
                @if (Model.IsSyncing)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    <span>Syncing...</span>
                }
                else
                {
                    <i class="bi bi-cloud-download"></i>
                    <span> Sync</span>
                }
            </button>
        </form>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.SyncMessage))
{
    <div class="alert alert-info">@Model.SyncMessage</div>
}

<form method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-3">
            <select name="documentType" class="form-select" onchange="this.form.submit()">
                <option value="">-- All Document Types --</option>
                @foreach (DocumentType docType in docTypes)
                {
                    <option value="@docType" selected="@(Model.DocumentType == docType.ToString())">@docType</option>
                }
            </select>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Document Type</th>
                    <th>Requested Date</th>
                    <th>Requested By</th>
                    <th>Student Admission ID</th>
                </tr>
            </thead>
            <tbody>
                @{int count = 1;}
                @foreach (var request in Model.StudentRequests)
                {
                    <tr>
                        <td>@(count++)</td>
                        <td>
                            <span class="badge bg-@GetBadgeClass(request.DocumentType)">
                                @request.DocumentType
                            </span>
                        </td>
                        <td>@request.RequestedDate.ToLocalTime()</td>
                        <td>@request.Requestedby</td>
                        <td>@request.StudentAdmissionId</td>
                    </tr>
                }
            </tbody>
        </table>
        
        @if (!Model.StudentRequests.Any())
        {
            <p class="text-center text-muted py-4">No student requests found. Click Sync to fetch data.</p>
        }
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" asp-page="./StudentRequests" asp-route-page="1" asp-route-documentType="@Model.DocumentType">First</a>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-page="./StudentRequests" asp-route-page="@(Model.CurrentPage - 1)" asp-route-documentType="@Model.DocumentType">Previous</a>
                </li>
            }
            
            @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-page="./StudentRequests" asp-route-page="@i" asp-route-documentType="@Model.DocumentType">@i</a>
                </li>
            }
            
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" asp-page="./StudentRequests" asp-route-page="@(Model.CurrentPage + 1)" asp-route-documentType="@Model.DocumentType">Next</a>
                </li>
                <li class="page-item">
                    <a class="page-link" asp-page="./StudentRequests" asp-route-page="@Model.TotalPages" asp-route-documentType="@Model.DocumentType">Last</a>
                </li>
            }
        </ul>
    </nav>
}

<p class="text-center text-muted">Showing @Model.StudentRequests.Count of @Model.TotalCount requests</p>

@functions {
    string GetBadgeClass(DocumentType docType) => docType switch
    {
        DocumentType.Transcript => "primary",
        DocumentType.CharacterCertificate => "success",
        DocumentType.MigrationCertificate => "info",
        DocumentType.ProvisionalCertificate => "warning",
        DocumentType.OriginalCertificate => "danger",
        _ => "secondary"
    };
}