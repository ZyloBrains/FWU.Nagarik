@page
@model FWU.Nagarik.Api.Pages.Dashboard.LogsModel
@{
    ViewData["Title"] = "Verification Logs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Verification Logs</h2>
</div>

<form method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-3">
            <input type="text" name="searchRegdNo" class="form-control" placeholder="Search Regd No" value="@Model.SearchRegdNo">
        </div>
        <div class="col-md-3">
            <select name="searchStatus" class="form-select">
                <option value="">All Status</option>
                <option value="Success" selected="@(Model.SearchStatus == "Success")">Success</option>
                <option value="NotFound" selected="@(Model.SearchStatus == "NotFound")">Not Found</option>
                <option value="Error" selected="@(Model.SearchStatus == "Error")">Error</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-body">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Regd No</th>
                    <th>Dob</th>
                    <th>Name</th>
                    <th>Program</th>
                    <th>Status</th>
                    <th>Verified At</th>
                </tr>
            </thead>
            <tbody>
                @{int i = 1;}
                @foreach (var log in Model.Logs)
                {
                    <tr>
                        <td>@(i++)</td>
                        <td>@log.RegdNo</td>
                        <td>@log.DobAD</td>
                        <td>@log.FirstName @log.LastName</td>
                        <td>@log.ProgramName</td>
                        <td>
                            <span class="badge bg-@(log.VerificationStatus == "Success" ? "success" : log.VerificationStatus == "NotFound" ? "warning" : "danger")">
                                @log.VerificationStatus
                            </span>
                        </td>
                        <td>@log.VerifiedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
        
        @if (!Model.Logs.Any())
        {
            <p class="text-center text-muted py-4">No records found</p>
        }
    </div>
</div>

<div class="mt-3">
    <nav>
        <ul class="pagination justify-content-end">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="?page=@(Model.CurrentPage - 1)">Previous</a>
                </li>
            }
            <li class="page-item active"><span class="page-link">@Model.CurrentPage</span></li>
            @if (Model.Logs.Any())
            {
                <li class="page-item">
                    <a class="page-link" href="?page=@(Model.CurrentPage + 1)">Next</a>
                </li>
            }
        </ul>
    </nav>
</div>